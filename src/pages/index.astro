---
import { defaultLang, useTranslations } from "../i18n/ui";

const t = useTranslations(defaultLang);

const title = `Rafael Chicovis | ${t("hero.role")}`;
const description = t("hero.description");
const siteUrl = "https://chicovis.dev";
const ogImage = `${siteUrl}/og-image.jpg`;

const lang = defaultLang;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content="Rafael Chicovis" />
    <link rel="canonical" href={`${siteUrl}/${lang}/`} />

    <link rel="alternate" hreflang="pt" href={`${siteUrl}/pt/`} />
    <link rel="alternate" hreflang="en" href={`${siteUrl}/en/`} />
    <link
      rel="alternate"
      hreflang="x-default"
      href={`${siteUrl}/${defaultLang}/`}
    />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${siteUrl}/${lang}/`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={`${siteUrl}/${lang}/`} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />

    <meta http-equiv="refresh" content={`0;url=/${defaultLang}/`} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Rafael Chicovis",
        "jobTitle": "Software Engineer",
        "url": "https://chicovis.dev",
        "sameAs": [
          "https://github.com/RafaelKC",
          "https://linkedin.com/in/rafael-chicovis"
        ]
      }
    </script>
  </head>
</html>
